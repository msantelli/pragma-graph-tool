exports[`export parity for curved-overlap.json > LaTeX document is identical > latex 1`] = `
"\\documentclass[border=5mm]{standalone}
\\usepackage{tikz}
\\usetikzlibrary{positioning, shapes.geometric, arrows.meta, fit, backgrounds}

\\begin{document}

\\begin{tikzpicture}[>=Stealth, thick, font=\\small]

% --- Node styles ---
\\tikzset{
  % MUD styles (Brandom, Between Saying and Doing)
  vocabulary/.style={ellipse, draw=black, thick,
    minimum width=2.8cm, minimum height=1.2cm,
    text width=2.2cm, text centered, align=center},
  practice/.style={rectangle, rounded corners=3pt, draw=black, thick,
    minimum width=2.8cm, minimum height=1.2cm,
    text width=2.4cm, text centered, align=center},
  custom/.style={circle, draw=black, thick,
    minimum size=1.5cm, text width=1.0cm, text centered, align=center},
  container/.style={rectangle, draw=black, dashed, rounded corners=4pt,
    inner sep=12pt},
  % Edge styles
  pv/.style={->, thick},
  vp/.style={->, thick},
  pp/.style={->, thick},
  vv/.style={->, thick},
  resultant/.style={->, thick, dashed},
  unmarked/.style={->, thick, gray!60},
  customedge/.style={->, thick},
}

% --- Nodes ---
\\node[vocabulary] (V1) at (-5.00, 3.13) {V1};
\\node[practice] (P1) at (5.00, 3.13) {P1};
\\node[vocabulary] (V2) at (0.00, -3.13) {V2};

% --- Edges ---
\\draw[vp] (V1) to[bend right=23] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {first} (P1);
\\draw[vp] (V1) to[bend right=8] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {second parallel} (P1);
\\draw[pv] (P1) to[bend left=8] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {reverse} (V1);
\\draw[pv] (P1) to[bend left=23] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {reverse parallel} (V1);
\\draw[feedback] (P1) to[loop above, looseness=5] node[above, font=\\scriptsize] {self} (P1);
\\draw[vv] (V1) -- node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {VV} (V2);
\\draw[unmarked] (V2) -- (P1);

\\end{tikzpicture}

\\end{document}"
`;

