  <path d="M 200.00 128.00 L 200.00 275.00" stroke="#333333" stroke-width="2" stroke-dasharray="none" fill="none" marker-end="url(#arrowhead)" stroke-linecap="round" />
  <text class="edge-text" x="188.00" y="201.50" transform="rotate(90.00, 188.00, 201.50)" fill="#333333" font-size="12" paint-order="stroke fill" stroke="white" stroke-width="3">incongruity</text>
  <path d="M 250.00 277.48 Q 366.64 224.96 479.57 119.15" stroke="#333333" stroke-width="2" stroke-dasharray="none" fill="none" marker-end="url(#arrowhead)" stroke-linecap="round" />
  <text class="edge-text" x="373.66" y="223.16" transform="rotate(-34.60, 373.66, 223.16)" fill="#333333" font-size="12" paint-order="stroke fill" stroke="white" stroke-width="3">feedback</text>
  <path d="M 250.00 287.50 C 330.00 287.50 330.00 312.50 250.00 312.50" stroke="#555555" stroke-width="2" stroke-dasharray="none" fill="none" marker-end="url(#arrowhead)" stroke-linecap="round" />
  <text class="edge-text" x="280.00" y="270.00" fill="#555555" font-size="12" paint-order="stroke fill" stroke="white" stroke-width="3">iterate</text>
  <path d="M 526.82 108.05 Q 600.00 130.00 650.00 115.00" stroke="#333333" stroke-width="2" stroke-dasharray="none" fill="none" marker-end="url(#arrowhead)" stroke-linecap="round" />
  <text class="edge-text" x="593.42" y="134.74" transform="rotate(3.23, 593.42, 134.74)" fill="#333333" font-size="12" paint-order="stroke fill" stroke="white" stroke-width="3">congruity</text>
  <path d="M 474.47 111.50 Q 333.36 175.04 226.68 275.00" stroke="#333333" stroke-width="2" stroke-dasharray="none" fill="none" marker-end="url(#arrowhead)" stroke-linecap="round" />
  <text class="edge-text" x="334.26" y="172.46" transform="rotate(-33.42, 334.26, 172.46)" fill="#333333" font-size="12" paint-order="stroke fill" stroke="white" stroke-width="3">test-fail</text>
  <path d="M 526.82 91.95 Q 600.00 70.00 650.00 85.00" stroke="#333333" stroke-width="2" stroke-dasharray="none" fill="none" marker-end="url(#arrowhead)" stroke-linecap="round" />
  <text class="edge-text" x="593.42" y="65.26" transform="rotate(-3.23, 593.42, 65.26)" fill="#333333" font-size="12" paint-order="stroke fill" stroke="white" stroke-width="3">exit</text>

  <!-- Nodes -->
  <path d="M 200.00,65.00 L 235.00,100.00 L 200.00,135.00 L 165.00,100.00 Z" fill="#FFFFFF" stroke="#333333" stroke-width="2" />
  <text x="200" y="100" font-size="14" class="node-text" fill="#333333" text-anchor="middle">Test incongruity</text>
  <rect x="150.00" y="275.00" width="100.00" height="50.00" rx="10" fill="#FFFFFF" stroke="#333333" stroke-width="2" />
  <text x="200" y="300" font-size="14" class="node-text" fill="#333333" text-anchor="middle">Hammer</text>
  <path d="M 500.00,65.00 L 535.00,100.00 L 500.00,135.00 L 465.00,100.00 Z" fill="#FFFFFF" stroke="#333333" stroke-width="2" />
  <text x="500" y="100" font-size="14" class="node-text" fill="#333333" text-anchor="middle">Re-test</text>
  <rect x="650.00" y="75.00" width="100.00" height="50.00" rx="10" fill="#FFFFFF" stroke="#333333" stroke-width="2" />
  <text x="700" y="100" font-size="14" class="node-text" fill="#333333" text-anchor="middle">Exit</text>
</svg>"
`;

exports[`export parity for tote-cycle.json > TikZ code is identical > tikz 1`] = `
"\\begin{tikzpicture}[>=Stealth, thick, font=\\small]

% --- Node styles ---
\\tikzset{
  % TOTE styles (Miller et al., Plans and the Structure of Behavior)
  test/.style={diamond, draw=black, thick, aspect=2,
    minimum width=2cm, text width=1.4cm, text centered, align=center},
  operate/.style={rectangle, draw=black, thick,
    minimum width=2.5cm, minimum height=1cm,
    text width=2.1cm, text centered, align=center},
  exitnode/.style={rectangle, draw=black, thick,
    minimum width=1.5cm, minimum height=0.8cm,
    text width=1.1cm, text centered, align=center},
  custom/.style={circle, draw=black, thick,
    minimum size=1.5cm, text width=1.0cm, text centered, align=center},
  container/.style={rectangle, draw=black, dashed, rounded corners=4pt,
    inner sep=12pt},
  % Edge styles
  sequence/.style={->, thick},
  feedback/.style={->, thick},
  exitedge/.style={->, thick},
  unmarked/.style={->, thick, gray!60},
  customedge/.style={->, thick},
}

% --- Nodes ---
\\node[test] (T1) at (-5.36, 2.14) {Test incongruity};
\\node[operate] (O1) at (-5.36, -2.14) {Hammer};
\\node[test] (T2) at (1.07, 2.14) {Re-test};
\\node[exitnode] (X1) at (5.36, 2.14) {Exit};

% --- Edges ---
\\draw[sequence] (T1) -- node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {incongruity} (O1);
\\draw[feedback] (O1) to[bend right=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {feedback} (T2);
\\draw[feedback] (O1) to[loop above, looseness=5] node[above, font=\\scriptsize] {iterate} (O1);
\\draw[exitedge] (T2) to[bend right=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {congruity} (X1);
\\draw[sequence] (T2) to[bend left=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {test-fail} (O1);
\\draw[exitedge] (T2) to[bend left=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {exit} (X1);

\\end{tikzpicture}"
`;
