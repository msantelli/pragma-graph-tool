exports[`export parity for full-mud.json > TikZ code is identical > tikz 1`] = `
"\\begin{tikzpicture}[>=Stealth, thick, font=\\small]

% --- Node styles ---
\\tikzset{
  % MUD styles (Brandom, Between Saying and Doing)
  vocabulary/.style={ellipse, draw=black, thick,
    minimum width=2.8cm, minimum height=1.2cm,
    text width=2.2cm, text centered, align=center},
  practice/.style={rectangle, rounded corners=3pt, draw=black, thick,
    minimum width=2.8cm, minimum height=1.2cm,
    text width=2.4cm, text centered, align=center},
  % TOTE styles (Miller et al., Plans and the Structure of Behavior)
  test/.style={diamond, draw=black, thick, aspect=2,
    minimum width=2cm, text width=1.4cm, text centered, align=center},
  operate/.style={rectangle, draw=black, thick,
    minimum width=2.5cm, minimum height=1cm,
    text width=2.1cm, text centered, align=center},
  exitnode/.style={rectangle, draw=black, thick,
    minimum width=1.5cm, minimum height=0.8cm,
    text width=1.1cm, text centered, align=center},
  custom/.style={circle, draw=black, thick,
    minimum size=1.5cm, text width=1.0cm, text centered, align=center},
  container/.style={rectangle, draw=black, dashed, rounded corners=4pt,
    inner sep=12pt},
  % Edge styles
  pv/.style={->, thick},
  vp/.style={->, thick},
  pp/.style={->, thick},
  vv/.style={->, thick},
  resultant/.style={->, thick, dashed},
  sequence/.style={->, thick},
  feedback/.style={->, thick},
  exitedge/.style={->, thick},
  unmarked/.style={->, thick, gray!60},
  customedge/.style={->, thick},
}

% --- Nodes ---
\\node[vocabulary] (V1) at (-6.14, 3.07) {V base\\\\ {\\scriptsize\\itshape context-homogeneous}};
\\node[vocabulary] (V2) at (-0.68, 3.07) {V meta\\\\ pragmatic metavocabulary};
\\node[practice] (P1) at (-6.14, -0.34) {P autonomous};
\\node[practice] (P2) at (-0.68, -0.34) {P dependent};
\\node[test] (T1) at (3.41, 3.07) {Test node};
\\node[operate] (O1) at (3.41, -0.34) {Operate node};
\\node[exitnode] (X1) at (6.14, 1.36) {Exit node};
\\node[custom] (C1) at (-3.41, -3.07) {Custom node};

% --- Edges ---
\\draw[pv] (P1) -- node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {1: PV} (V1);
\\draw[vp] (V1) to[bend right=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {2: VP} (P2);
\\draw[pp] (P1) to[bend right=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {PP} (P2);
\\draw[vv] (V1) to[bend right=23] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {VV} (V2);
\\draw[pv] (P2) to[bend right=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {PV-suff witness} (V2);
\\draw[pv] (P2) to[bend left=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {PV-nec} (V1);
\\draw[vp] (V2) -- node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {VP-suff} (P1);
\\draw[vp] (V2) to[bend left=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {VP-nec} (P2);
\\draw[pp] (P2) to[bend left=15] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {PP-suff} (P1);
\\draw[pp] (P1) -- node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {PP-nec} (C1);
\\draw[vv] (V2) to[bend right=8] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {VV-suff} (V1);
\\draw[vv] (V1) to[bend left=8] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {VV-nec} (V2);
\\draw[resultant] (V1) to[bend left=23] node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {res: VV} (V2);
\\draw[unmarked] (C1) -- (P2);
\\draw[customedge] (C1) -- node[midway, fill=white, inner sep=1pt, font=\\scriptsize] {bespoke relation} (V1);

\\end{tikzpicture}"
`;

